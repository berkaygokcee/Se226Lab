
num_tasks = int(input("Enter number of tasks: "))

tasks = {}

# Collect task data
for _ in range(num_tasks):
    task_name = input("Enter task name: ")
    dep_count = int(input(f"How many dependencies for {task_name}? "))

    dependencies = []
    for i in range(dep_count):
        dep = input(f"Enter dependency {i+1}: ")
        dependencies.append(dep)

    tasks[task_name] = dependencies


print("\nTASK STRUCTURE:")
for task, deps in tasks.items():
    print(f"{task} -> {deps}")


initial_tasks = [task for task, deps in tasks.items() if len(deps) == 0]

print("\nINITIAL TASKS (no dependencies):")
if initial_tasks:
    for t in initial_tasks:
        print(t)
else:
    print("None")


completed = set()
execution_order = []

print("\nEXECUTION ORDER:")

step = 1

while len(completed) < len(tasks):
    progress = False

    for task, deps in tasks.items():
        # Check if task can be executed
        if task not in completed and all(dep in completed for dep in deps):
            completed.add(task)
            execution_order.append(task)
            print(f"Step {step}: {task}")
            step += 1
            progress = True


    if not progress:
        break


if len(completed) == len(tasks):
    print("\nALL TASKS COMPLETED SUCCESSFULLY")
else:
    print("\nNo task can be started.")
    print("\nERROR: Circular dependency detected!")

    remaining = [task for task in tasks if task not in completed]
    print("These tasks could not be completed:")
    for task in remaining:
        print(task)